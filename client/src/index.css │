*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Segoe UI', sans-serif;
  background: #f5f7fa;
  color: #1a1a2e;
}

.navbar {
  display: flex; justify-content: space-between; align-items: center;
  padding: 1rem 2rem; background: #1a1a2e; color: white;
}
.brand { color: #f5c518; font-size: 1.3rem; font-weight: 700; text-decoration: none; }
.nav-links { display: flex; gap: 1rem; align-items: center; }
.nav-links a, .nav-links button {
  color: white; text-decoration: none; background: none;
  border: 1px solid #444; padding: 6px 14px; border-radius: 6px; cursor: pointer;
}
.nav-links button:hover, .nav-links a:hover { background: #2d2d50; }

.container { max-width: 800px; margin: 2rem auto; padding: 0 1rem; }

h1, h2 { margin-bottom: 1.2rem; }

.auth-card {
  background: white; padding: 2rem; border-radius: 12px;
  box-shadow: 0 2px 12px rgba(0,0,0,.08); max-width: 440px; margin: 0 auto;
}
.auth-card form { display: flex; flex-direction: column; gap: 0.8rem; margin-top: 1rem; }
.auth-card input {
  padding: 10px 14px; border: 1px solid #ddd; border-radius: 8px; font-size: 0.95rem;
}
.auth-card input:focus { outline: none; border-color: #4f46e5; }

.poll-card {
  background: white; border-radius: 12px; padding: 1.2rem 1.5rem;
  margin-bottom: 1rem; box-shadow: 0 1px 6px rgba(0,0,0,.07);
}
.poll-card h3 { margin-bottom: 0.3rem; }
.meta { color: #888; font-size: 0.85rem; margin-bottom: 0.6rem; }
.option-chip {
  display: inline-block; background: #ede9fe; color: #4f46e5;
  border-radius: 20px; padding: 3px 10px; font-size: 0.8rem; margin-right: 6px;
}
.btn-link { color: #4f46e5; text-decoration: none; font-weight: 600; font-size: 0.9rem; }

.poll-detail { background: white; border-radius: 12px; padding: 2rem; }
.option-row {
  display: flex; align-items: center; gap: 0.8rem;
  padding: 10px; border: 1px solid #eee; border-radius: 8px;
  margin-bottom: 0.5rem; cursor: pointer; transition: background 0.15s;
}
.option-row:hover { background: #f0efff; }
.option-row.selected { border-color: #4f46e5; background: #ede9fe; }
.bar-wrap { flex: 1; background: #f0f0f0; border-radius: 4px; height: 8px; overflow: hidden; }
.bar { height: 100%; background: #4f46e5; border-radius: 4px; transition: width 0.4s; }
.pct { font-size: 0.82rem; color: #555; min-width: 70px; text-align: right; }

.btn-primary {
  background: #4f46e5; color: white; border: none; padding: 10px 22px;
  border-radius: 8px; cursor: pointer; font-size: 0.95rem; margin-top: 1rem;
}
.btn-secondary {
  background: none; border: 1px solid #4f46e5; color: #4f46e5;
  padding: 8px 18px; border-radius: 8px; cursor: pointer; margin-top: 0.6rem;
}
.subscribe-box { margin-top: 1.5rem; padding: 1rem; background: #f9f9ff; border-radius: 8px; }
.subscribe-box input { padding: 8px 12px; border: 1px solid #ddd; border-radius: 6px; width: 60%; }
.subscribe-box button { margin-left: 8px; padding: 8px 16px; background: #4f46e5; color: white; border: none; border-radius: 6px; cursor: pointer; }
.analytics-box { margin-top: 1rem; padding: 1rem; background: #f0fdf4; border-radius: 8px; }
.error   { color: #dc2626; font-size: 0.9rem; }
.success { color: #16a34a; font-size: 0.9rem; }